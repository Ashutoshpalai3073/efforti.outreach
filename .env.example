# Copy to .env and edit. Load with: export $(cat .env | xargs)
APP_BASE_URL=http://localhost:8000   # public URL for unsubscribe links in prod
# MANUAL_SEND_ONLY=true: the app NEVER sends on its own — you click "Send due
# batch" on the dashboard. Required on sleep-prone hosts like Render's free tier,
# where the background scheduler can't be trusted to fire on time. Set to false
# only on an always-on host if you want automatic 5-min send cycles.
MANUAL_SEND_ONLY=true
BUSINESS_HOUR_START=9         # only used by the automatic scheduler (not manual)
BUSINESS_HOUR_END=17
BOUNCE_PAUSE_THRESHOLD=0.03
JITTER_MAX_MINUTES=45
# Apollo defaults (per pull): 20 brands x 5 top execs each. Override in the UI.
APOLLO_API_KEY=
ANTHROPIC_API_KEY=           # or GROQ_API_KEY for the AI openers
