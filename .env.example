# Copy to .env and edit. Load with: export $(cat .env | xargs)
DRY_RUN=true                 # set to false only when ready to send for real
APP_BASE_URL=http://localhost:8000   # public URL for unsubscribe links in prod
BUSINESS_HOUR_START=9
BUSINESS_HOUR_END=17
BOUNCE_PAUSE_THRESHOLD=0.03
JITTER_MAX_MINUTES=45
